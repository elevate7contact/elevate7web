# Stripe: usado por api/create-checkout.js para crear la sesión de pago
# de las consultorías de 30/60 min, y por api/stripe-webhook.js para
# verificar la firma del webhook.
STRIPE_SECRET_KEY=sk_live_or_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Supabase: usado solo por api/stripe-webhook.js para registrar las
# reservas confirmadas en la tabla "bookings". Opcional — si no se
# configura, el webhook seguirá respondiendo 200 pero no guardará nada.
VITE_SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# URL pública del sitio, usada como fallback si VERCEL_PROJECT_PRODUCTION_URL
# no está disponible (Vercel la define automáticamente en producción).
VITE_SITE_URL=https://elevatezevenia.com
