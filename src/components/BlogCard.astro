---
export interface Props {
  title: string;
  description: string;
  href: string;
  date: string;
  lang: 'ES' | 'EN';
}

const { title, description, href, date, lang } = Astro.props;

const formattedDate = new Date(`${date}T00:00:00`).toLocaleDateString(lang === 'EN' ? 'en-US' : 'es-CO', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<a
  href={href}
  class="card group flex flex-col justify-between transition hover:border-brand-400/40 hover:bg-white/[0.05]"
>
  <div>
    <div class="mb-4 flex items-center gap-3">
      <span class="rounded-full bg-brand-500/15 px-3 py-1 text-xs font-semibold uppercase tracking-wider text-brand-300">
        {lang}
      </span>
      <time datetime={date} class="text-xs text-slate-500">{formattedDate}</time>
    </div>
    <h3 class="text-xl font-semibold text-white transition group-hover:text-brand-300">{title}</h3>
    <p class="mt-3 text-sm leading-relaxed text-slate-400">{description}</p>
  </div>
  <span class="mt-6 inline-flex items-center gap-1 text-sm font-semibold text-accent-400">
    {lang === 'EN' ? 'Read article' : 'Leer artículo'}
    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
    </svg>
  </span>
</a>
