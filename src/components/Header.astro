---
export interface Props {
  lang?: 'es' | 'en';
}
const { lang = 'es' } = Astro.props;

const nav =
  lang === 'en'
    ? [
        { href: '/', label: 'Home' },
        { href: '/servicios', label: 'Services' },
        { href: '/nosotros', label: 'About' },
        { href: '/casos', label: 'Case Studies' },
        { href: '/blog', label: 'Blog' },
      ]
    : [
        { href: '/', label: 'Inicio' },
        { href: '/servicios', label: 'Servicios' },
        { href: '/nosotros', label: 'Nosotros' },
        { href: '/casos', label: 'Casos' },
        { href: '/blog', label: 'Blog' },
      ];

const ctaLabel = lang === 'en' ? 'Book a call' : 'Agenda una llamada';
const currentPath = new URL(Astro.request.url).pathname;
---

<header class="sticky top-0 z-50 border-b border-white/5 bg-ink-950/80 backdrop-blur-md">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4 sm:px-8">
    <a href="/" class="flex items-center gap-2.5 font-display text-lg font-bold text-white">
      <img src="/logo.png" alt="Elevate 7 IA" width="32" height="32" class="h-8 w-8 rounded-lg" />
      Elevate 7 IA
    </a>

    <nav class="hidden items-center gap-8 md:flex">
      {nav.map((item) => (
        <a
          href={item.href}
          class:list={[
            'text-sm font-medium transition hover:text-white',
            currentPath === item.href ? 'text-white' : 'text-slate-400',
          ]}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="hidden md:block">
      <a href="/contacto" class="btn-primary !px-5 !py-2.5 text-sm">{ctaLabel}</a>
    </div>

    <button
      id="menu-toggle"
      type="button"
      aria-label="Abrir menú"
      aria-expanded="false"
      class="flex h-10 w-10 items-center justify-center rounded-lg border border-white/10 text-white md:hidden"
    >
      <svg id="icon-open" xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg id="icon-close" xmlns="http://www.w3.org/2000/svg" class="hidden h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <div id="mobile-menu" class="hidden border-t border-white/5 px-6 pb-6 md:hidden">
    <nav class="flex flex-col gap-4 pt-4">
      {nav.map((item) => (
        <a href={item.href} class="text-sm font-medium text-slate-300 hover:text-white">
          {item.label}
        </a>
      ))}
      <a href="/contacto" class="btn-primary mt-2 text-sm">{ctaLabel}</a>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  toggle?.addEventListener('click', () => {
    const isHidden = menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    iconOpen?.classList.toggle('hidden');
    iconClose?.classList.toggle('hidden');
    toggle.setAttribute('aria-expanded', isHidden ? 'true' : 'false');
  });
</script>
