---
export interface Step {
  tag: string;
  title: string;
  description: string;
  icon: 'search' | 'plan' | 'build' | 'chart';
}

export interface Props {
  steps: Step[];
}

const { steps } = Astro.props;

const ICONS: Record<Step['icon'], string> = {
  search: 'M21 21l-4.34-4.34M17 10.5a6.5 6.5 0 11-13 0 6.5 6.5 0 0113 0Z',
  plan: 'M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2M9 5a2 2 0 0 0 2 2h2a2 2 0 0 0 2-2M9 5a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2M9 12h6M9 16h6',
  build:
    'M12 15a3 3 0 1 0 0-6 3 3 0 0 0 0 6ZM19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 1 1-4 0v-.09a1.65 1.65 0 0 0-1-1.51 1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 1 1 0-4h.09a1.65 1.65 0 0 0 1.51-1 1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 1 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 1 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1Z',
  chart: 'M3 3v18h18M8 17V11M13 17V7M18 17v-4',
};
---

<div class="mx-auto max-w-4xl" data-component="process-steps">
  <div class="relative mb-8 flex items-start justify-between sm:mb-10">
    <div class="absolute left-0 right-0 top-6 h-px bg-white/10" aria-hidden="true"></div>
    {steps.map((step, i) => (
      <button
        type="button"
        role="tab"
        aria-selected={i === 0 ? 'true' : 'false'}
        aria-controls={`step-panel-${i + 1}`}
        data-step={i + 1}
        class={`step-btn relative z-10 flex flex-1 flex-col items-center gap-2 px-1 text-center sm:gap-3 ${i === 0 ? 'is-active' : ''}`}
      >
        <span class="step-number flex h-11 w-11 shrink-0 items-center justify-center rounded-full border-2 border-white/15 bg-ink-950 font-display text-sm font-bold text-slate-500 transition sm:h-12 sm:w-12 sm:text-base">
          {i + 1}
        </span>
        <span class="step-title text-[11px] font-semibold uppercase leading-tight tracking-wide text-slate-500 transition sm:text-xs">
          {step.title}
        </span>
      </button>
    ))}
  </div>

  <div class="relative">
    {steps.map((step, i) => (
      <div
        id={`step-panel-${i + 1}`}
        data-panel={i + 1}
        class={`step-panel card text-center ${i === 0 ? '' : 'hidden'}`}
        role="tabpanel"
      >
        <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-2xl bg-accent-500/10 text-accent-400">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
            <path stroke-linecap="round" stroke-linejoin="round" d={ICONS[step.icon]} />
          </svg>
        </div>
        <span class="eyebrow mt-5 !mb-0">{step.tag}</span>
        <h3 class="mt-3 text-2xl font-bold text-white">{step.title}</h3>
        <p class="mx-auto mt-3 max-w-xl text-base leading-relaxed text-slate-300">{step.description}</p>
      </div>
    ))}
  </div>
</div>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('[data-component="process-steps"] [data-step]');
  const panels = document.querySelectorAll<HTMLElement>('[data-component="process-steps"] [data-panel]');

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const step = btn.getAttribute('data-step');
      buttons.forEach((b) => {
        const active = b === btn;
        b.classList.toggle('is-active', active);
        b.setAttribute('aria-selected', active ? 'true' : 'false');
      });
      panels.forEach((p) => {
        p.classList.toggle('hidden', p.getAttribute('data-panel') !== step);
      });
    });
  });
</script>
