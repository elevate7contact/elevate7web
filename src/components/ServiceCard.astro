---
export interface Props {
  number: string;
  title: string;
  description: string;
}

const { number, title, description } = Astro.props;
---

<div class="card">
  <span class="font-display text-sm font-semibold text-accent-400">{number}</span>
  <h2 class="mt-3 text-xl font-semibold text-white sm:text-2xl">{title}</h2>
  <p class="mt-4 text-sm leading-relaxed text-slate-400 sm:text-base">{description}</p>
</div>
