---
export interface Step {
  icon: 'chat' | 'agent' | 'database' | 'bell' | 'chart' | 'ads';
  label: string;
}

export interface Props {
  steps: Step[];
  class?: string;
}

const { steps, class: className = '' } = Astro.props;

const ICONS: Record<Step['icon'], string> = {
  chat: 'M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 0 1-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8Z',
  agent:
    'M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 5h10a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2Zm2 4h6v6H9V9Z',
  database:
    'M12 3c-4.42 0-8 1.79-8 4s3.58 4 8 4 8-1.79 8-4-3.58-4-8-4ZM4 7v5c0 2.21 3.58 4 8 4s8-1.79 8-4V7M4 12v5c0 2.21 3.58 4 8 4s8-1.79 8-4v-5',
  bell: 'M15 17h5l-1.405-1.405A2.032 2.032 0 0 1 18 14.158V11a6.002 6.002 0 0 0-4-5.659V5a2 2 0 1 0-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 1 1-6 0v-1m6 0H9',
  chart: 'M3 3v18h18M8 17V11M13 17V7M18 17v-4',
  ads: 'M11 5.882V19.24a1.76 1.76 0 0 1-3.417.592l-2.147-6.15M18 13a3 3 0 1 0 0-6M5.436 13.683A4.001 4.001 0 0 1 7 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 0 1-1.564-.317Z',
};
---

<div class={`workflow-diagram flex flex-col items-stretch gap-2 sm:flex-row sm:items-center sm:justify-between sm:gap-0 ${className}`}>
  {steps.map((step, i) => (
    <>
      <div class="flex flex-1 flex-col items-center gap-3 rounded-2xl border border-white/10 bg-white/[0.02] px-4 py-5 text-center">
        <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-accent-500/10 text-accent-400">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
            <path stroke-linecap="round" stroke-linejoin="round" d={ICONS[step.icon]} />
          </svg>
        </div>
        <p class="text-sm font-semibold text-white">{step.label}</p>
      </div>
      {i < steps.length - 1 && (
        <div class="flex shrink-0 items-center justify-center text-accent-500/50 sm:px-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 rotate-90 sm:rotate-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
          </svg>
        </div>
      )}
    </>
  ))}
</div>
