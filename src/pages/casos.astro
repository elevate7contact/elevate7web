---
import BaseLayout from '../layouts/BaseLayout.astro';
import CaseCard from '../components/CaseCard.astro';

const title = 'Casos de Éxito en Automatización con IA | Elevate 7 IA';
const description =
  'Resultados reales de automatización con IA en salud, educación, finanzas e inmobiliario. Métricas concretas, sin promesas vacías. Agenda tu diagnóstico.';

const cases = [
  {
    sector: 'Salud',
    title: 'Clínica privada: de 4 horas a 3 minutos en respuesta a nuevos pacientes',
    description:
      'Un agente de IA implementado sobre WhatsApp Business API califica consultas entrantes, identifica el tipo de servicio requerido y agenda citas automáticamente. Antes de la implementación, el tiempo promedio de respuesta era de 4 horas en horario laboral y nulo fuera de él. Después: respuesta en menos de 3 minutos, 24 horas al día. La tasa de conversión de consulta a cita agendada aumentó 40% en el primer mes.',
    metrics: ['-96% tiempo de respuesta', '+40% conversión'],
  },
  {
    sector: 'Educación',
    title: 'Institución educativa: 8 horas semanales recuperadas en reportes de campañas',
    description:
      'Pipeline automatizado con BigQuery y Looker Studio para consolidar y visualizar el rendimiento de campañas Google Ads. Antes: un analista dedicaba 8 horas semanales a descargar datos, cruzarlos en Excel y armar el reporte para dirección. Después: dashboard actualizado automáticamente cada 24 horas con alertas por Slack cuando alguna métrica sale del rango esperado. Cero intervención manual. El analista redirigió ese tiempo a optimización de campañas.',
    metrics: ['8h semanales recuperadas', '0 reportes manuales'],
  },
  {
    sector: 'Servicios financieros',
    title: 'Empresa de servicios financieros: -34% en CPA en 90 días',
    description:
      'Reestructuración completa de campañas Google Ads con keyword research asistido por IA, segmentación por tipo de producto financiero y copy generado y testeado sistemáticamente con inteligencia artificial. Smart Bidding configurado con señales de conversión limpias. En los primeros 90 días el costo por adquisición bajó 34% y el volumen de solicitudes calificadas aumentó 28% con el mismo presupuesto.',
    metrics: ['-34% CPA', '+28% leads calificados'],
  },
];

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: 'https://elevatezevenia.com/' },
    { '@type': 'ListItem', position: 2, name: 'Casos', item: 'https://elevatezevenia.com/casos' },
  ],
};
---

<BaseLayout title={title} description={description} path="/casos" schema={breadcrumbSchema}>
  <section class="section pb-8 pt-20 sm:pt-24">
    <div class="mx-auto max-w-3xl text-center">
      <span class="eyebrow">Casos de éxito</span>
      <h1 class="text-4xl font-bold leading-tight sm:text-5xl">Resultados Reales de Automatización con IA</h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-slate-400">
        Estos son proyectos reales con métricas reales. Los nombres de los clientes son anónimos por confidencialidad, pero los números son verificables internamente. Cada caso parte de un diagnóstico de proceso, define métricas antes de implementar y mide el impacto en las primeras cuatro semanas post-lanzamiento.
      </p>
    </div>
  </section>

  <section class="section pt-8">
    <div class="grid grid-cols-1 gap-6 lg:grid-cols-3">
      {cases.map((c) => (
        <CaseCard sector={c.sector} title={c.title} description={c.description} metrics={c.metrics} />
      ))}
    </div>
  </section>

  <section class="section pt-0">
    <div class="card mx-auto flex max-w-4xl flex-col items-center gap-6 text-center sm:flex-row sm:justify-between sm:text-left">
      <div>
        <h2 class="text-2xl font-bold sm:text-3xl">¿Quieres resultados como estos?</h2>
        <p class="mt-2 text-slate-400">Empecemos con un diagnóstico gratuito de tus procesos.</p>
      </div>
      <a href="/contacto#opciones" class="btn-primary whitespace-nowrap">Agenda una llamada</a>
    </div>
  </section>
</BaseLayout>
