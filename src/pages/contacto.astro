---
import BaseLayout from '../layouts/BaseLayout.astro';
import BookingOptions from '../components/BookingOptions.astro';

const title = 'Contacto — Agenda tu Diagnóstico Gratuito | Elevate 7 IA';
const description =
  'Escríbenos y agenda una llamada gratuita con Elevate 7 IA. Te decimos qué procesos automatizar primero en tu empresa y con qué retorno esperado.';

const contactPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: 'Contacto — Elevate 7 IA',
  url: 'https://elevatezevenia.com/contacto',
  about: {
    '@type': 'Organization',
    name: 'Elevate 7 IA',
    address: { '@type': 'PostalAddress', addressLocality: 'Bogotá', addressCountry: 'CO' },
  },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: 'https://elevatezevenia.com/' },
    { '@type': 'ListItem', position: 2, name: 'Contacto', item: 'https://elevatezevenia.com/contacto' },
  ],
};
---

<BaseLayout title={title} description={description} path="/contacto" schema={[contactPageSchema, breadcrumbSchema]}>
  <section class="section pb-8 pt-20 sm:pt-24">
    <div class="mx-auto max-w-3xl text-center">
      <span class="eyebrow">Contacto</span>
      <h1 class="text-4xl font-bold leading-tight sm:text-5xl">Hablemos de tu Empresa</h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-slate-400">
        Cuéntanos qué proceso te quita más tiempo. En la primera llamada te decimos si tiene sentido automatizarlo y con qué retorno esperado — sin compromiso.
      </p>
    </div>
  </section>

  <section class="section pt-0">
    <div class="mb-10 text-center">
      <span class="eyebrow">Escríbenos</span>
      <h2 class="text-3xl font-bold sm:text-4xl">Cuéntanos qué necesitas</h2>
    </div>
    <div class="mx-auto grid max-w-5xl grid-cols-1 gap-8 lg:grid-cols-[1.2fr_1fr]">
      <form id="contact-form" class="card space-y-5">
        <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
          <div>
            <label for="name" class="mb-2 block text-sm font-medium text-slate-300">Nombre</label>
            <input
              type="text"
              id="name"
              name="Nombre"
              required
              class="w-full rounded-xl border border-white/10 bg-white/5 px-4 py-3 text-sm text-white placeholder-slate-500 outline-none transition focus:border-brand-400"
              placeholder="Tu nombre"
            />
          </div>
          <div>
            <label for="company" class="mb-2 block text-sm font-medium text-slate-300">Empresa</label>
            <input
              type="text"
              id="company"
              name="Empresa"
              class="w-full rounded-xl border border-white/10 bg-white/5 px-4 py-3 text-sm text-white placeholder-slate-500 outline-none transition focus:border-brand-400"
              placeholder="Nombre de tu empresa"
            />
          </div>
        </div>

        <div>
          <label for="email" class="mb-2 block text-sm font-medium text-slate-300">Email</label>
          <input
            type="email"
            id="email"
            name="Email"
            required
            class="w-full rounded-xl border border-white/10 bg-white/5 px-4 py-3 text-sm text-white placeholder-slate-500 outline-none transition focus:border-brand-400"
            placeholder="tu@empresa.com"
          />
        </div>

        <div>
          <label for="message" class="mb-2 block text-sm font-medium text-slate-300">
            ¿Qué proceso te gustaría automatizar?
          </label>
          <textarea
            id="message"
            name="Mensaje"
            rows="5"
            required
            class="w-full rounded-xl border border-white/10 bg-white/5 px-4 py-3 text-sm text-white placeholder-slate-500 outline-none transition focus:border-brand-400"
            placeholder="Cuéntanos brevemente sobre tu empresa y el problema que quieres resolver"
          ></textarea>
        </div>

        <button type="submit" id="contact-submit" class="btn-primary w-full sm:w-auto">
          Enviar por WhatsApp
        </button>
        <p class="text-xs text-slate-500">Al enviar, se abre WhatsApp con tu mensaje ya redactado.</p>
      </form>

      <div class="space-y-6">
        <div class="card">
          <h2 class="text-lg font-semibold text-white">Contacto directo</h2>
          <ul class="mt-4 space-y-3 text-sm text-slate-400">
            <li>
              <span class="block text-slate-500">WhatsApp</span>
              <a
                href="https://wa.me/573153973371"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-1.5 text-white hover:text-brand-300"
              >
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" class="h-4 w-4 fill-current">
                  <path d="M16.003 2.667C8.638 2.667 2.667 8.638 2.667 16c0 2.354.627 4.562 1.72 6.468L2.667 29.333l7.07-1.697A13.27 13.27 0 0 0 16.003 29.333C23.365 29.333 29.333 23.362 29.333 16S23.365 2.667 16.003 2.667zm0 2.4c5.977 0 10.93 4.953 10.93 10.933s-4.953 10.933-10.93 10.933a10.9 10.9 0 0 1-5.563-1.52l-.394-.237-4.196 1.007.998-3.998-.262-.411A10.9 10.9 0 0 1 5.07 16c0-5.98 4.953-10.933 10.933-10.933zm-3.17 5.6c-.215 0-.563.08-.858.4-.295.32-1.128 1.102-1.128 2.686s1.155 3.117 1.315 3.332c.16.215 2.264 3.456 5.492 4.71 2.72 1.052 3.27.843 3.858.79.587-.053 1.896-.775 2.164-1.523.268-.748.268-1.39.187-1.523-.08-.134-.294-.214-.615-.374-.32-.16-1.896-.937-2.19-1.044-.295-.107-.51-.16-.724.16-.214.32-.83 1.044-.99 1.258-.16.215-.348.24-.669.08-.32-.16-1.35-.498-2.572-1.588-.95-.849-1.59-1.896-1.777-2.217-.186-.32-.02-.494.14-.654.144-.144.32-.374.48-.561.16-.187.214-.32.32-.534.107-.214.054-.4-.027-.56-.08-.16-.724-1.746-.99-2.39-.267-.643-.534-.535-.724-.535z" />
                </svg>
                Escríbenos por WhatsApp
              </a>
            </li>
            <li>
              <span class="block text-slate-500">Email</span>
              <a href="mailto:elevate7.contact@gmail.com" class="text-white hover:text-brand-300">
                elevate7.contact@gmail.com
              </a>
            </li>
            <li>
              <span class="block text-slate-500">Ubicación</span>
              <span class="text-white">Bogotá, Colombia — atención remota worldwide</span>
            </li>
            <li>
              <span class="block text-slate-500">Horario</span>
              <span class="text-white">Lunes a viernes, 9:00 a.m. – 6:00 p.m. (COT)</span>
            </li>
          </ul>
        </div>

        <div class="card">
          <h2 class="text-lg font-semibold text-white">¿Qué pasa después de escribirnos?</h2>
          <ol class="mt-4 space-y-3 text-sm text-slate-400">
            <li><span class="font-semibold text-accent-400">1.</span> Agendamos una llamada de 30 minutos.</li>
            <li><span class="font-semibold text-accent-400">2.</span> Revisamos tus procesos actuales y detectamos oportunidades.</li>
            <li><span class="font-semibold text-accent-400">3.</span> Te enviamos una propuesta con alcance, tiempos y retorno esperado.</li>
          </ol>
        </div>
      </div>
    </div>
  </section>

  <section class="section pt-0">
    <BookingOptions />
  </section>
</BaseLayout>

<script>
  const WHATSAPP_NUMBER = '573153973371';

  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const submitBtn = document.getElementById('contact-submit') as HTMLButtonElement | null;

  form?.addEventListener('submit', (e) => {
    e.preventDefault();

    const name = (document.getElementById('name') as HTMLInputElement)?.value.trim();
    const company = (document.getElementById('company') as HTMLInputElement)?.value.trim();
    const email = (document.getElementById('email') as HTMLInputElement)?.value.trim();
    const message = (document.getElementById('message') as HTMLTextAreaElement)?.value.trim();

    const lines = [
      `Hola, soy ${name}${company ? ` de ${company}` : ''}.`,
      `Mi correo: ${email}`,
      '',
      message,
    ];

    const text = encodeURIComponent(lines.join('\n'));
    const url = `https://wa.me/${WHATSAPP_NUMBER}?text=${text}`;

    if (submitBtn) {
      submitBtn.textContent = 'Abriendo WhatsApp...';
      setTimeout(() => {
        submitBtn.textContent = 'Enviar por WhatsApp';
      }, 2500);
    }

    window.open(url, '_blank', 'noopener,noreferrer');
  });
</script>
